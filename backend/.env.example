APP_NAME="Oppla One Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT
APP_TIMEZONE=Europe/Rome

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=oppla_one_manager
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Use 'redis' only if Redis is installed:
# QUEUE_CONNECTION=redis

# Stripe Configuration
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=it_IT

# Stripe Payment Gateway
STRIPE_KEY=your_stripe_public_key
STRIPE_SECRET=your_stripe_secret_key

# VivaWallet Integration
VIVAWALLET_CLIENT_ID=
VIVAWALLET_CLIENT_SECRET=
VIVAWALLET_MERCHANT_ID=
VIVAWALLET_API_KEY=

# Fattureincloud Configuration
FIC_API_UID=
FIC_API_KEY=
FIC_COMPANY_ID=

# OPPLA Platform API
OPPLA_API_URL=https://api.oppla.it
OPPLA_API_KEY=
OPPLA_API_SECRET=

# Tookan Fleet Management API (Rider Tracking)
# Get your API key from: https://app.tookanapp.com/#/app/settings/apikey
TOOKAN_API_KEY=

# Email Configuration (Production)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@oppla.it"
MAIL_FROM_NAME="${APP_NAME}"

# PWA Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@oppla.it

# Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-south-1
AWS_BUCKET=oppla-documents
AWS_USE_PATH_STYLE_ENDPOINT=false

# Banking APIs (se disponibili)
INTESA_API_KEY=
INTESA_API_SECRET=

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ==================================================================
# OPPLA ADMIN PANEL (Filament)
# ==================================================================
# URL pannello admin Opplà (Filament)
OPPLA_ADMIN_URL=https://api.oppla.delivery

# Credenziali accesso admin panel Filament
OPPLA_ADMIN_EMAIL=your_email@example.com
OPPLA_ADMIN_PASSWORD=your_password_here

# GraphQL API (per query pubbliche - se disponibile)
OPPLA_GRAPHQL_URL=https://api.oppla.delivery/graphql
OPPLA_API_KEY=

# Sync automatico 3 volte al giorno: 08:00, 14:00, 20:00 (Europe/Rome)
# ==================================================================

# ==================================================================
# OPPLA DATABASE - PostgreSQL (DEPRECATED - DO NOT USE)
# ==================================================================
# Direct database access is deprecated. Use Filament panel authentication instead.
# OPPLA_DB_HOST=
# OPPLA_DB_PORT=5432
# OPPLA_DB_NAME=
# OPPLA_DB_USER=
# OPPLA_DB_PASSWORD=
# OPPLA_DB_SCHEMA=public
# ==================================================================

# ==================================================================
# OPPLA ADMIN PANEL CREDENTIALS (Python Scripts - DEPRECATED)
# ==================================================================
# Use OPPLA_ADMIN_EMAIL and OPPLA_ADMIN_PASSWORD above instead
# Usato dagli script Python per operazioni headless (es: chiusura massiva ristoranti)
OPPLA_ADMIN_URL=https://admin.oppla.it
OPPLA_ADMIN_EMAIL=your-admin-email@oppla.it
OPPLA_ADMIN_PASSWORD=your-secure-password
# ==================================================================

# ==================================================================
# FATTURE IN CLOUD API v2 (OAuth 2.0)
# ==================================================================
# API base URL
FIC_BASE_URL=https://api-v2.fattureincloud.it

# OAuth 2.0 Credentials (from your FIC app)
FIC_CLIENT_ID=your-client-id-here
FIC_CLIENT_SECRET=your-client-secret-here
FIC_REDIRECT_URI="${APP_URL}/api/fatture-in-cloud/callback"

# API Settings
FIC_TIMEOUT=30
FIC_RETRY_ATTEMPTS=3
FIC_RETRY_DELAY=1000
# ==================================================================

VITE_APP_NAME="${APP_NAME}"
